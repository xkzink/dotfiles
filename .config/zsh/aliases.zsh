alias st='open -a /Applications/Sublime\ Text.app'
 # 添加自启动项: aria2
alias startaria2="launchctl load ~/Library/LaunchAgents/aria2.plist"
# 删除自启动项: aria2
alias stoparia2="launchctl unload ~/Library/LaunchAgents/aria2.plist"
alias vim=nvim
# alias to open aseprite
alias aseprite="open $HOME/Applications/Aseprite/build/bin/aseprite"
